# ═══════════════════════════════════════════════════════════════════════
# ResearchMind Pro — 环境变量配置
# 复制为 .env 并填写实际值（.env 已在 .gitignore，不会提交到 Git）
# ═══════════════════════════════════════════════════════════════════════

# ── 应用基础 ──────────────────────────────────────────────────────────
ENVIRONMENT="local"          # local | dev | staging | production
DEBUG=true
LOG_LEVEL="INFO"
LOG_JSON=false               # 生产环境改为 true

# ═══════════════════════════════════════════════════════════════════════
# LLM API Keys（至少填一个）
# ═══════════════════════════════════════════════════════════════════════

# ── DeepSeek（推荐，性价比极高）──────────────────────────────────────
# 注册：https://platform.deepseek.com
# 价格：input ¥1/1M tokens，output ¥2/1M tokens（deepseek-chat，2025）
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# ── Qwen（阿里云百炼）────────────────────────────────────────────────
# 注册：https://bailian.console.aliyun.com
# 注意：环境变量名是 QWEN_API_KEY，填入百炼控制台的 API Key
QWEN_API_KEY="sk-..."
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ── OpenAI（可选，有则 Embedding 自动用 text-embedding-3-small）──────
# OPENAI_API_KEY="sk-..."

# ── Anthropic（可选）─────────────────────────────────────────────────
# ANTHROPIC_API_KEY="sk-ant-..."

# ═══════════════════════════════════════════════════════════════════════
# Agent 模型路由策略
# 格式：  "provider:model_name"
# 若指定的 provider 未配置 API Key，自动 fallback 到第一个可用 provider
# ═══════════════════════════════════════════════════════════════════════

# --- 方案 A：同时有 DeepSeek + Qwen（推荐，Critic 异源评判）---
PLANNER_MODEL_SPEC="deepseek:deepseek-chat"
WRITER_MODEL_SPEC="deepseek:deepseek-chat"
ANALYST_MODEL_SPEC="deepseek:deepseek-chat"
RESEARCH_MODEL_SPEC="deepseek:deepseek-chat"
CRITIC_MODEL_SPEC="qwen:qwen-plus"           # 用 Qwen 评判 DeepSeek 输出，避免同源偏差

# --- 方案 B：只有 DeepSeek ---
# PLANNER_MODEL_SPEC="deepseek:deepseek-chat"
# WRITER_MODEL_SPEC="deepseek:deepseek-chat"
# ANALYST_MODEL_SPEC="deepseek:deepseek-chat"
# RESEARCH_MODEL_SPEC="deepseek:deepseek-chat"
# CRITIC_MODEL_SPEC="deepseek:deepseek-chat"

# --- 方案 C：只有 Qwen ---
# PLANNER_MODEL_SPEC="qwen:qwen-plus"
# WRITER_MODEL_SPEC="qwen:qwen-max"
# ANALYST_MODEL_SPEC="qwen:qwen-plus"
# RESEARCH_MODEL_SPEC="qwen:qwen-turbo"       # Research 用 turbo 省钱
# CRITIC_MODEL_SPEC="qwen:qwen-max"           # Critic 用最强模型

# --- 方案 D：追求最强推理（Planner 用 DeepSeek-R1，其余 V3）---
# PLANNER_MODEL_SPEC="deepseek:deepseek-reasoner"   # R1 推理最强但慢 3-5x
# WRITER_MODEL_SPEC="deepseek:deepseek-chat"
# ANALYST_MODEL_SPEC="deepseek:deepseek-chat"
# RESEARCH_MODEL_SPEC="deepseek:deepseek-chat"
# CRITIC_MODEL_SPEC="qwen:qwen-max"

# ═══════════════════════════════════════════════════════════════════════
# Embedding（向量化，RAG 必需）
# ═══════════════════════════════════════════════════════════════════════
# qwen   → text-embedding-v3（1024维，免费额度充足，推荐）
# openai → text-embedding-3-small（1536维，精度略高，需 OpenAI Key）
EMBEDDING_PROVIDER="qwen"
EMBEDDING_DIMENSIONS=1024

# ═══════════════════════════════════════════════════════════════════════
# 辅助工具（可选，不配置则对应功能降级）
# ═══════════════════════════════════════════════════════════════════════

# Cohere Rerank（不配置则跳过 Rerank，检索质量略降）
# 注册：https://cohere.com（有免费额度）
# COHERE_API_KEY=""

# Tavily Web Search（不配置则禁用实时网络搜索）
# 注册：https://tavily.com（每月 1000 次免费）
# TAVILY_API_KEY=""

# LlamaCloud PDF 解析（不配置则用基础 PyMuPDF 解析）
# LLAMA_CLOUD_API_KEY=""

# ═══════════════════════════════════════════════════════════════════════
# 数据库（与 docker-compose.yml 保持一致）
# ═══════════════════════════════════════════════════════════════════════
POSTGRES_HOST="localhost"     # Docker Compose 内部访问改为 "postgres"
POSTGRES_PORT=5432
POSTGRES_USER="researchmind"
POSTGRES_PASSWORD="researchmind_dev"
POSTGRES_DB="researchmind"

REDIS_HOST="localhost"        # Docker Compose 内部访问改为 "redis"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

QDRANT_HOST="localhost"       # Docker Compose 内部访问改为 "qdrant"
QDRANT_PORT=6333
QDRANT_COLLECTION="knowledge_base"

# ═══════════════════════════════════════════════════════════════════════
# Agent 行为参数
# ═══════════════════════════════════════════════════════════════════════
MAX_RESEARCH_ITERATIONS=5     # Agentic RAG 最大检索轮次
MAX_CRITIC_ITERATIONS=3       # Critic 最大重写轮次
MAX_PARALLEL_RESEARCH=3       # 并行 Research Agent 数量
TASK_TIMEOUT_SECONDS=120
HITL_ENABLED=true
MAX_TOKENS_PER_TASK=100000    # 超出则中断，防止 Token 爆炸
MIN_QUALITY_SCORE=0.75        # Critic 低于此分数触发重写

# ═══════════════════════════════════════════════════════════════════════
# 认证
# ═══════════════════════════════════════════════════════════════════════
# 生产环境生成：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32"
AUTH_DISABLED=true            # 开发阶段 true，生产必须改为 false

# ═══════════════════════════════════════════════════════════════════════
# 可观测性（可选）
# ═══════════════════════════════════════════════════════════════════════
# LangSmith Agent Trace（注册：https://smith.langchain.com）
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="researchmind-pro"
